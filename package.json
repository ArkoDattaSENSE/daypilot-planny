{
  "name": "planny",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Planny static PWA for GitHub Pages with Firebase Spark backend.",
  "scripts": {
    "build": "node scripts/build-pages.cjs",
    "start": "python3 -m http.server 8000",
    "test": "node scripts/smoke-test.cjs && node scripts/gemini-parser-suite.cjs --offline",
    "test:gemini": "node scripts/gemini-parser-suite.cjs --offline",
    "test:gemini:live": "node scripts/gemini-parser-suite.cjs --live",
    "deploy:github": "git --git-dir=.planny_git --work-tree=. push -u origin main",
    "deploy:firebase": "node scripts/deploy-firebase.cjs"
  },
  "keywords": [
    "planny",
    "scheduler",
    "firebase",
    "pwa"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "firebase-tools": "^10.9.2"
  }
}
