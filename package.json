{
  "name": "daypilot-planny",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "DayPilot / Planny static PWA for GitHub Pages with Firebase Spark backend.",
  "scripts": {
    "build": "node scripts/build-pages.cjs",
    "start": "python3 -m http.server 8000",
    "test": "node scripts/smoke-test.cjs",
    "deploy:github": "git --git-dir=.planny_git --work-tree=. push -u origin main",
    "deploy:firebase": "FIREBASE_CLI_DISABLE_UPDATE_CHECK=true XDG_CONFIG_HOME=/tmp/firebase-config XDG_CACHE_HOME=/tmp/firebase-cache ./node_modules/.bin/firebase deploy --only firestore:rules,hosting"
  },
  "keywords": [
    "daypilot",
    "scheduler",
    "firebase",
    "pwa"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "firebase-tools": "^10.9.2"
  }
}
